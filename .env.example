# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/voice_agent

# ─────────────────────────────────────────────
# Groq  (LLM + STT)
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo

# ─────────────────────────────────────────────
# Cartesia  (TTS)
# ─────────────────────────────────────────────
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxxxxxxxxxxxxx
CARTESIA_VOICE_ID=db6b0ed5-d5d3-463d-ae85-518a07d3c2b4
CARTESIA_MODEL_ID=sonic-3.5

# ─────────────────────────────────────────────
# Jina AI  (Embeddings — replaces OpenAI, free tier available)
# Get your free API key: https://jina.ai/?sui=apikey
# ─────────────────────────────────────────────
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JINA_EMBEDDING_MODEL=jina-embeddings-v5-text-small

# ─────────────────────────────────────────────
# OpenAI  (optional — only if switching back to OpenAI embeddings)
# ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────
# Bot
# ─────────────────────────────────────────────
DEFAULT_BOT=healthcare

# ─────────────────────────────────────────────
# Server / CORS  (set in render.yaml for production)
# WEB_ORIGIN: the deployed frontend URL allowed by CORS
# ─────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000
